<div class="page-header">
  <div>
    <h1 class="page-title">Settings</h1>
    <div class="page-subtitle">app preferences</div>
  </div>
</div>
<div style="max-width: 680px;">
  <div class="card mb-3">
    <div class="card-header">Appearance</div>
    <div class="settings-row">
      <div>
        <p class="mb-0">Theme</p>
        <span class="text-muted" style="font-size:12px;">Choose your preferred color scheme</span>
      </div>
      <select class="form-select" style="width: 130px;">
        <option selected>Dark</option>
        <option>Light</option>
        <option>System</option>
      </select>
    </div>
    <div class="settings-row">
      <div>
        <p class="mb-0">Language</p>
        <span class="text-muted" style="font-size:12px;">Select display language</span>
      </div>
      <select class="form-select" style="width: 130px;">
        <option selected>English</option>
        <option>Español</option>
      </select>
    </div>
  </div>
  <div class="card mb-3">
    <div class="card-header">Notifications</div>
    <div class="settings-row">
      <div>
        <p class="mb-0">Order updates</p>
        <span class="text-muted" style="font-size:12px;">Status changes, shipping confirmations</span>
      </div>
      <input class="form-check-input" type="checkbox" checked>
    </div>
    <div class="settings-row">
      <div>
        <p class="mb-0">Delivery alerts</p>
        <span class="text-muted" style="font-size:12px;">When your order is out for delivery</span>
      </div>
      <input class="form-check-input" type="checkbox" checked>
    </div>
    <div class="settings-row">
      <div>
        <p class="mb-0">Promotions</p>
        <span class="text-muted" style="font-size:12px;">Deals, new arrivals and offers</span>
      </div>
      <input class="form-check-input" type="checkbox">
    </div>
  </div>
  <div class="card mb-3">
    <div class="card-header">Privacy</div>
    <div class="settings-row">
      <div>
        <p class="mb-0">Order history visibility</p>
        <span class="text-muted" style="font-size:12px;">Allow account managers to view your orders</span>
      </div>
      <input class="form-check-input" type="checkbox" checked>
    </div>
  </div>
</div>
