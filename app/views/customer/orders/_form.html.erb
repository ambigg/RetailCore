<div class="container py-4">
  <div class="page-header">
    <div>
      <h1 class="page-title">Create Order</h1>
    </div>
  </div>
  <div class="row">
    <div class="col-md-7 col-lg-8">
      <% if @order.errors.any? %>
        <div class="alert alert-danger">
          <% @order.errors.full_messages.each do |msg| %>
            <p class="mb-0"><%= msg %></p>
          <% end %>
        </div>
      <% end %>
      <%= form_with model: [:customer, @order] do |f| %>
        <div class="mb-3">
          <%= f.label :name, class: "form-label" %>
          <%= f.text_field :name, value: current_user.name, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :shipping_address, class: "form-label" %>
          <%= f.text_field :shipping_address, value: current_user.address, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :phone, class: "form-label" %>
          <%= f.text_field :phone, value: current_user.phone, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :fake_billing_information, class: "form-label" %>
          <%= f.text_field :billing_information, class: "form-control" %>
        </div>
        <%= f.submit @order.new_record? ? "Create Order" : "Update Order", class: "btn btn-primary" %>
      <% end %>
    </div>
    <div class="col-md-5 col-lg-4">
      <div class="card">
        <div class="card-header">
          <h5 class="mb-0">Your Cart</h5>
        </div>
        <div class="card-body">
          <% if @items.any? %>
            <ul class="list-group list-group-flush">
              <% @items.each do |item| %>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                  <div>
                    <strong><%= item[:variant].product.name %></strong>
                    <br>
                    <small>
                      <%= item[:variant].size %> |
                      <%= number_to_currency(item[:variant].price) %> x <%= item[:quantity] %>
                    </small>
                  </div>
                  <span><%= number_to_currency(item[:variant].price * item[:quantity]) %></span>
                </li>
              <% end %>
            </ul>
            <div class="mt-3 d-flex justify-content-between">
              <strong>Total:</strong>
              <strong class="text-accent"><%= number_to_currency(@cart.total) %></strong>
            </div>
          <% else %>
            <p class="text-muted">Your cart is empty</p>
          <% end %>
        </div>
        <div class="card-footer">
          <%= link_to "View Cart", cart_path, class: "btn btn-outline w-100" %>
        </div>
      </div>
    </div>
  </div>
</div>
