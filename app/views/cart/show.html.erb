<div class="page-header">
  <h1 class="page-title">Cart</h1>
  <%= link_to "Back to Products", root_path, class: "btn btn-outline" %>
</div>
<% if @items.any? %>
  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Variant</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        <% @items.each do |item| %>
          <tr>
            <td><%= item[:variant].product.name %></td>
            <td class="text-muted"><%= item[:variant].sku %></td>
            <td><%= number_to_currency(item[:variant].price) %></td>
            <td><%= item[:quantity] %></td>
            <td class="text-accent"><%= number_to_currency(item[:variant].price * item[:quantity]) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <div class="d-flex justify-content-end align-items-center gap-2 mt-3">
    <span class="page-subtitle">Total: <span class="text-accent"><%= number_to_currency(@cart.total) %></span></span>
    <%= button_to "Clear Cart", clear_cart_path, method: :delete, class: "btn btn-outline" %>
    <%= link_to "Checkout", new_customer_order_path, class: "btn btn-primary" %>
  </div>
<% else %>
  <div class="text-center py-5">
    <i class="bi bi-inbox display-1 text-muted"></i>
    <p class="page-subtitle mt-3">You have no items in your cart.</p>
  </div>
<% end %>
