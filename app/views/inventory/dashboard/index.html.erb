<div class="page-header">
  <div>
    <div class="page-title">Dashboard</div>
    <div class="page-subtitle"><%= Time.current.year %> · warehouse: central</div>
  </div>
  <%= link_to new_inventory_product_path, class: "btn btn-primary" do %>
    <i class="bi bi-plus-lg"></i> Add Product
  <% end %>
</div>
<div class="row mb-4">
  <div class="col-md-3 mb-3">
    <%= link_to inventory_products_path, class: "card hover-lift text-decoration-none" do %>
      <div class="card-body text-center">
        <div class="page-subtitle mb-2">TOTAL PRODUCTS</div>
        <div class="page-title"><%= @total_products %></div>
      </div>
    <% end %>
  </div>
  <div class="col-md-3 mb-3">
    <%= link_to inventory_products_path, class: "card hover-lift text-decoration-none" do %>
      <div class="card-body text-center">
        <div class="page-subtitle mb-2">TOTAL STOCK</div>
        <div class="page-title"><%= @total_stock%></div>
      </div>
    <% end %>
  </div>
  <div class="col-md-3 mb-3">
    <%= link_to inventory_products_path, class: "card hover-lift text-decoration-none" do %>
      <div class="card-body text-center">
        <div class="page-subtitle mb-2">LOW STOCK</div>
        <div class="page-title text-orange"><%= @low_stock%></div>
      </div>
    <% end %>
  </div>
  <div class="col-md-3 mb-3">
    <%= link_to inventory_products_path, class: "card hover-lift text-decoration-none" do %>
      <div class="card-body text-center">
        <div class="page-subtitle mb-2">PENDING ORDERS</div>
        <div class="page-title text-accent"><%= @pending_orders%></div>
      </div>
    <% end %>
  </div>
</div>
<div class="row">
  <div class="col-md-6">
    <h3 class="page-title mb-3">Stock Overview</h3>
    <div class="card">
      <table class="table">
        <thead>
          <tr>
            <th>PRODUCT</th>
            <th>SKU</th>
            <th>LOCATION</th>
            <th>STOCK</th>
          </tr>
        </thead>
        <tbody>
          <% @products.each do |product| %>
            <% product.product_variants.each do |variant| %>
              <tr>
                <td><%= product.name %></td>
                <td class="text-muted"><%= variant.sku %></td>
                <td>
                  <% locations = variant.inventories.map do |inv|
                       inv.branch ? inv.branch.name : "General"
                  end %>
                  <%= locations.uniq.join(", ") %>
                </td>
                <td class="text-accent"><%= variant.inventories.sum(:quantity) %></td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="col-md-6">
    <h3 class="page-title mb-3">Recent Orders</h3>
    <div class="card">
      <table class="table">
        <thead>
          <tr>
            <th>ID</th>
            <th>EMAIL</th>
            <th>STATUS</th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr>
              <td><%= order.id %></td>
              <td><%= order.customer.email%></td>
              <td><%= order.status %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
