<div class="page-header">
  <div>
    <h1 class="page-title"><%= @product.name %></h1>
    <div class="page-subtitle"><%= @product.active? ? "Active" : "Inactive" %></div>
  </div>
  <div class="d-flex gap-2">
    <%= link_to "Edit", edit_inventory_product_path(@product), class: "btn btn-outline" %>
    <%= button_to "Delete", inventory_product_path(@product), method: :delete,
        data: { turbo_confirm: "Are you sure?" }, class: "btn btn-outline" %>
    <%= link_to "Back", inventory_products_path, class: "btn btn-outline" %>
  </div>
</div>
<p class="text-muted mb-1"><%= @product.description %></p>
<p class="text-muted mb-4"><%= @product.category %></p>
<div class="page-header">
  <h3 class="page-title">Variants</h3>
  <%= link_to "Add Variant", new_inventory_product_product_variant_path(@product), class: "btn btn-primary" %>
</div>
<% if @product.product_variants.any? %>
  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>SKU</th>
          <th>Color</th>
          <th>Size</th>
          <th>Material</th>
          <th>Price</th>
          <th colspan="3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @product.product_variants.each do |variant| %>
          <tr>
            <td><%= variant.sku %></td>
            <td><%= variant.color %></td>
            <td><%= variant.size %></td>
            <td><%= variant.material %></td>
            <td class="text-accent"><%= number_to_currency(variant.price) %></td>
            <td><%= link_to "Stock", inventory_product_product_variant_inventories_path(@product, variant) %></td>
            <td><%= link_to "Edit", edit_inventory_product_product_variant_path(@product, variant) %></td>
            <td><%= link_to "Delete", inventory_product_product_variant_path(@product, variant),
                data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">No variants yet.</p>
<% end %>
