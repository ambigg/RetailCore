<div class="page-header">
  <div>
    <h1 class="page-title">Products</h1>
  </div>
  <%= link_to new_inventory_product_path, class: "btn btn-primary" do %>
    <i class="bi bi-plus-lg"></i> Add Product
  <% end %>
</div>
<% if @products.any? %>
  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th>Category</th>
          <th>Variants</th>
          <th colspan="3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <tr>
            <td><%= product.name %></td>
            <td class="text-muted"><%= product.description %></td>
            <td><%= product.category %></td>
            <td class="text-accent"><%= product.product_variants.count %></td>
            <td><%= link_to 'Show', inventory_product_path(product) %></td>
            <td><%= link_to 'Edit', edit_inventory_product_path(product) %></td>
            <td><%= link_to 'Delete', inventory_product_path(product), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="text-center py-5">
    <i class="bi bi-inbox display-1 text-muted"></i>
    <p class="page-subtitle mt-3">You don't have any products yet.</p>
    <%= link_to new_inventory_product_path, class: "btn btn-primary mt-2" do %>
      <i class="bi bi-plus-lg"></i> Create first product
    <% end %>
  </div>
<% end %>
