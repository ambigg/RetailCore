<h1>Branches Inventory</h1>
<% if @branches.any? %>
  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Address</th>
        <th>Phone</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @branches.each do |branch| %>
        <tr>
          <td><%= branch.name %></td>
          <td><%= branch.address %></td>
          <td><%= branch.phone %></td>
          <td><%= branch.status.humanize %></td>
          <td><%= link_to "View Stock", inventory_branch_path(branch) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No branches available.</p>
<% end %>
