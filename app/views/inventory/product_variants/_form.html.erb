<% if @variant.errors.any? %>
  <div class="alert alert-danger">
    <% @variant.errors.full_messages.each do |msg| %>
      <p class="mb-0"><%= msg %></p>
    <% end %>
  </div>
<% end %>
<%= form_with(model: [:inventory, @product, @variant]) do |f| %>
  <div class="mb-3">
    <%= f.label :sku, class: "form-label" %>
    <%= f.text_field :sku, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :color, class: "form-label" %>
    <%= f.text_field :color, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :size, class: "form-label" %>
    <%= f.text_field :size, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :material, class: "form-label" %>
    <%= f.text_field :material, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :price, class: "form-label" %>
    <%= f.number_field :price, step: 0.01, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :stock, class: "form-label" %>
    <%= f.number_field :stock, step: 1, min: 0, class: "form-control" %>
  </div>
  <%= f.submit @variant.new_record? ? "Create Variant" : "Update Variant", class: "btn btn-primary" %>
<% end %>
