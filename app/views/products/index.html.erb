<div class="page-header">
  <div>
    <h1 class="page-title">RETAILCORE</h1>
  </div>
</div>
<% if @products.any? %>
  <div class="row g-4">
    <% @products.each do |product| %>
      <div class="col-md-6 col-lg-4 col-xl-3">
        <div class="card h-100 hover-lift">
          <div style="height: 200px; background: var(--surface2); display: flex; align-items: center; justify-content: center; border-radius: var(--radius-md) var(--radius-md) 0 0;">
            <i class="bi bi-box" style="font-size: 4rem; color: var(--muted);"></i>
          </div>
          <div class="card-body d-flex flex-column">
            <h5 class="card-title fw-semibold mb-1"><%= product.name %></h5>
            <p class="text-muted small mb-2"><%= truncate(product.description, length: 80) %></p>
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="badge badge-accent"><%= product.category %></span>
              <span class="fw-bold text-accent">
                <%= number_to_currency(product.product_variants.minimum(:price) || 0) %>+
              </span>
            </div>
            <div class="mt-auto">
              <%= link_to product_path(product), class: "btn btn-outline w-100" do %>
                <i class="bi bi-eye me-2"></i> View Details
              <% end %>
            </div>
          </div>
          <div class="card-footer text-muted small">
            <i class="bi bi-shop me-1"></i> <%= product.user.email %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-5">
    <i class="bi bi-box" style="font-size: 3rem; color: var(--muted);"></i>
    <p class="text-muted mt-3">No products available.</p>
  </div>
<% end %>
